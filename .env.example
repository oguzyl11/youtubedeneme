SUPADATA_API_KEY=your_supadata_api_key
SECRET_KEY=generate_with_python_or_django_get_random_secret_key
DEBUG=False
# Örnek: alan adı, Docker healthcheck, doğrudan IP erişimi için VPS IP
ALLOWED_HOSTS=example.com,127.0.0.1,localhost
# HTTPS form gönderimi (CSRF): boş bırakılırsa ALLOWED_HOSTS'tan https:// ve http:// üretilir
# CSRF_TRUSTED_ORIGINS=https://example.com
# Nginx/Caddy arkasında TLS: varsayılan DEBUG=False iken açık; kapatmak için: USE_PROXY_SSL=False
